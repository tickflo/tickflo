@page "/reset-password"
@model Tickflo.Web.Pages.ResetPasswordModel
@{
    ViewData["Title"] = "Reset password";
}

<div class="flex min-h-[calc(100vh-6rem)] flex-col items-center justify-center">
    <div class="card w-full max-w-md bg-neutral-900/85 backdrop-blur shadow-2xl rounded-3xl border border-white/5 text-slate-100">
        <div class="card-body">
            <h2 class="card-title text-2xl font-bold mb-2">Reset password</h2>

            @if (!Model.IsTokenValid)
            {
                <p class="text-sm text-slate-400 mb-4">This password reset link is invalid or has expired.</p>
                @await Html.PartialAsync("_ErrorAlert", "Request a new link below.")
                <a href="/forgot-password" class="btn btn-primary mt-4 w-full rounded-full h-12">
                    Request a new link
                </a>
            }
            else
            {
                <p class="text-sm text-slate-400 mb-6">Resetting the password for <span class="text-slate-100">@Model.MaskedEmail</span>.</p>
                <form method="post" novalidate>
                    <fieldset class="fieldset">
                        <input type="hidden" asp-for="Token" />
                        <label class="label" for="password">
                            <span class="label-text text-slate-300">New password</span>
                        </label>
                        <input id="password" asp-for="Password" type="password" class="input validator bg-neutral-800/50 border-white/10 text-slate-100 focus:border-primary h-12 w-full" placeholder="New password" value="" />
                        <span asp-validation-for="Password" class="validator-hint"></span>
                        <label class="label" for="confirmPassword">
                            <span class="label-text text-slate-300">Confirm new password</span>
                        </label>
                        <input id="confirmPassword" asp-for="ConfirmPassword" type="password" class="input validator bg-neutral-800/50 border-white/10 text-slate-100 focus:border-primary h-12 w-full" placeholder="Confirm new password" value="" />
                        <span asp-validation-for="ConfirmPassword" class="validator-hint"></span>
                        @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
                        {
                            @await Html.PartialAsync("_ErrorAlert", Model.ErrorMessage)
                        }
                        <button type="submit" class="btn btn-primary mt-6 w-full rounded-full h-12">
                            Reset password
                        </button>
                    </fieldset>
                </form>
            }
            <div class="text-center mt-4 text-slate-400">
                Changed your mind?
                <a href="/login" class="link link-primary link-hover text-sm ml-1">
                    Back to sign in
                </a>
            </div>
        </div>
    </div>
</div>
